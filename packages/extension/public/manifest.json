{
  "manifest_version": 3,
  "name": "GENIE Graphify Capsule Visualizer",
  "version": "1.0.0",
  "description": "Visualize GENIE Wish Capsules and inject live memory into AI chat tools.",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage",
    "windows"
  ],
  "host_permissions": [
    "http://127.0.0.1:14747/*",
    "*://chatgpt.com/*",
    "*://claude.ai/*",
    "*://openrouter.ai/*",
    "*://grok.com/*",
    "*://gemini.google.com/*",
    "*://lovable.dev/*"
  ],
  "action": {
    "default_title": "GENIE Graphify",
    "default_popup": "popup.html"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://openrouter.ai/*",
        "*://grok.com/*",
        "*://gemini.google.com/*",
        "*://lovable.dev/*"
      ],
      "js": [
        "utils.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/lamp.png"
      ],
      "matches": [
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://openrouter.ai/*",
        "*://grok.com/*",
        "*://gemini.google.com/*",
        "*://lovable.dev/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
