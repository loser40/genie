{
  "name": "@genie-ai/desktop",
  "version": "1.0.0",
  "main": "dist/main.js",
  "scripts": {
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build:main": "tsc -p tsconfig.json",
    "build": "npm run build:renderer && npm run build:main",
    "dev": "npm run build:renderer && npm run build:main && electron dist/main.js",
    "start": "electron dist/main.js"
  },
  "dependencies": {
    "@genie-ai/core": "file:../core",
    "@genie-ai/server": "file:../server",
    "adm-zip": "^0.5.17",
    "electron-store": "^11.0.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.12"
  },
  "build": {
    "appId": "ai.genie.desktop",
    "productName": "GENIE",
    "files": [
      "dist/**",
      "renderer-dist/**",
      "assets/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/lamp.png"
    }
  }
}
